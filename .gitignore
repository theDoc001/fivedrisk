*.swp

# OS
.DS_Store

# Local dev
*.log

# Runtime artifacts (decision logs, benchmark DBs)
*.db
*.db-journal

# iCloud sync duplicates
* 2.*
* 2

# Pre-publish drafts (release deliberately with cosigner credit per master pitch §4.3).
# Use `docs/*` not `docs/` so negation patterns can re-include specific files
# (git cannot un-ignore a file whose parent directory is fully excluded).
docs/*
# Exception: quickstart.md is public onboarding, not a draft.
!docs/quickstart.md

# Calibration data lives in vault/testing/benchmarks/ until the v0.5.2
# comparison report ships (task #52)
benchmarks/aiid-reconstructions.yaml
